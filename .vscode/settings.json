{
  "python.defaultInterpreterPath": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
  "python.terminal.activateEnvironment": true,
  "terminal.integrated.cwd": "${workspaceFolder}",
  "terminal.integrated.defaultProfile.windows": "PowerShell (.venv)",
  "terminal.integrated.profiles.windows": {
    "PowerShell (.venv)": {
      "source": "PowerShell",
      "args": [
        "-NoExit",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "if (Test-Path .\\.venv\\Scripts\\Activate.ps1) { . .\\.venv\\Scripts\\Activate.ps1 }"
      ]
    },
    "Ubuntu WSL (.venv)": {
      "path": "C:\\Windows\\System32\\wsl.exe",
      "args": [
        "-d",
        "Ubuntu-24.04",
        "bash",
        "-lc",
        "cd \"$(wslpath '${workspaceFolder}')\" && if [ -f .venv-wsl/bin/activate ]; then source .venv-wsl/bin/activate; fi; exec bash"
      ]
    }
  },
  "terminal.integrated.defaultProfile.linux": "bash (.venv)",
  "terminal.integrated.profiles.linux": {
    "bash (.venv)": {
      "path": "bash",
      "args": [
        "-lc",
        "if [ -f .venv-wsl/bin/activate ]; then source .venv-wsl/bin/activate; fi; exec bash"
      ]
    }
  }
}
