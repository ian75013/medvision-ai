# Common
APP_NAME=medvision-ai
IMAGE_TAG=latest

# VPS targets
SSH_USER=ubuntu
SSH_HOST=1.2.3.4
SSH_PORT=22
APP_DIR=/opt/medvision-ai
GIT_REPO=git@github.com:your-org/medvision-ai.git
GIT_BRANCH=main

# AWS App Runner
AWS_REGION=eu-west-3
AWS_ACCOUNT_ID=123456789012
ECR_REPO_API=medvision-api
ECR_REPO_STREAMLIT=medvision-streamlit

# Azure Container Apps
AZ_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
AZ_RESOURCE_GROUP=rg-medvision
AZ_LOCATION=westeurope
AZ_ACR_NAME=medvisionacr
AZ_CONTAINERAPPS_ENV=medvision-env

# GCP Cloud Run
GCP_PROJECT_ID=my-gcp-project
GCP_REGION=europe-west1
GCP_ARTIFACT_REPO=medvision

# Kubernetes / k3s
KUBE_CONTEXT=
K8S_API_IMAGE=registry.example.com/medvision-api:latest
K8S_STREAMLIT_IMAGE=registry.example.com/medvision-streamlit:latest
