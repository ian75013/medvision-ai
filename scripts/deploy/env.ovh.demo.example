# Example OVH deployment env (fictive values)
APP_NAME=medvision-ai
IMAGE_TAG=latest

SSH_USER=ubuntu
SSH_HOST=vps.example.com
SSH_PORT=22

GIT_REPO=git@github.com:your-org/medvision-ai.git
GIT_BRANCH=main
APP_DIR=/opt/medvision-ai
MLFLOW_BIND_IP=10.8.0.1
MLFLOW_HOST_PORT=5000
API_BIND_IP=127.0.0.1
API_HOST_PORT=18000
STREAMLIT_BIND_IP=127.0.0.1
STREAMLIT_HOST_PORT=18501

# Optional remote sudo password (leave empty if NOPASSWD sudo)
SUDO_PASSWORD=
ASK_SUDO_PASSWORD=false

PROVISION_CADDY=true
API_DOMAIN=api.example.com
APP_DOMAIN=app.example.com
CADDY_EMAIL=admin@example.com
