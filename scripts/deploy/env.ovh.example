# OVH deployment environment
APP_NAME=medvision-ai
IMAGE_TAG=latest

# VPS access
SSH_USER=ubuntu
SSH_HOST=REPLACE_WITH_VPS_IP_OR_HOSTNAME
SSH_PORT=22

# Repository to deploy on VPS
GIT_REPO=REPLACE_WITH_GIT_REPO_URL
GIT_BRANCH=main
APP_DIR=/opt/medvision-ai

# Production MLflow binding on VPN interface only.
# Change MLFLOW_HOST_PORT if the port is already used on the VPS.
MLFLOW_BIND_IP=10.8.0.1
MLFLOW_HOST_PORT=5000

# Optional: if remote sudo asks a password, set it here.
# WARNING: this is sensitive. Prefer passwordless sudo when possible.
SUDO_PASSWORD=

# Safer alternative: prompt for sudo password at runtime (hidden input)
ASK_SUDO_PASSWORD=false

# Optional Caddy reverse proxy + TLS
PROVISION_CADDY=true
API_DOMAIN=api.REPLACE_WITH_YOUR_DOMAIN
APP_DOMAIN=app.REPLACE_WITH_YOUR_DOMAIN
CADDY_EMAIL=admin@REPLACE_WITH_YOUR_DOMAIN
