# ------------------------------------------------------------
# OVH quickstart (one command deployment)
#
# Complete ONLY these 4 lines first:
#   1) SSH_HOST
#   2) GIT_REPO
#   3) API_DOMAIN
#   4) APP_DOMAIN
#
# Then run:
#   scripts/deploy/deploy.ovh.sh docker .env.ovh
# ------------------------------------------------------------

APP_NAME=medvision-ai
IMAGE_TAG=latest

# VPS access
SSH_USER=ubuntu
SSH_HOST=REPLACE_WITH_VPS_IP_OR_HOSTNAME
SSH_PORT=22

# Repo to deploy on VPS
GIT_REPO=REPLACE_WITH_GIT_REPO_URL
GIT_BRANCH=main
APP_DIR=/opt/medvision-ai

# Automatic Caddy reverse proxy + TLS
PROVISION_CADDY=true
API_DOMAIN=api.REPLACE_WITH_YOUR_DOMAIN
APP_DOMAIN=app.REPLACE_WITH_YOUR_DOMAIN
CADDY_EMAIL=admin@REPLACE_WITH_YOUR_DOMAIN
